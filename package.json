{
  "name": "single-agent-cli-runtime",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json && node scripts/copy-agent-assets.mjs",
    "build:tui": "cargo build --manifest-path tui/Cargo.toml",
    "dev": "tsx src/cli/main.ts",
    "dev:tui": "npm run build:tui && tsx src/cli/main.ts",
    "test": "vitest run",
    "test:tui": "cargo test --manifest-path tui/Cargo.toml",
    "typecheck:test": "tsc -p tsconfig.test.json",
    "summary:smoke": "python3 src/tools/python/summary_worker.py",
    "summary:integration": "npm run test -- tests/tools/summary.test.ts"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24.7.2",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.82.0",
    "better-sqlite3": "^12.8.0",
    "execa": "^9.6.1",
    "openai": "^6.33.0",
    "picocolors": "^1.1.1",
    "proper-lockfile": "^4.1.2"
  }
}
